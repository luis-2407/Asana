    <ui:InvokeCode ContinueOnError="{x:Null}" Code="Try&#xD;&#xA;    Dim tempFolder As String = System.IO.Path.Combine(System.IO.Path.GetTempPath(), &quot;docx_edit&quot;)&#xD;&#xA;    &#xD;&#xA;    debugMsg = &quot;Step 1: Preparing temp folder&quot;&#xD;&#xA;    If System.IO.Directory.Exists(tempFolder) Then&#xD;&#xA;        System.IO.Directory.Delete(tempFolder, True)&#xD;&#xA;    End If&#xD;&#xA;    System.IO.Directory.CreateDirectory(tempFolder)&#xD;&#xA;    &#xD;&#xA;    debugMsg = &quot;Step 2: Extracting docx&quot;&#xD;&#xA;    System.IO.Compression.ZipFile.ExtractToDirectory(docPath, tempFolder)&#xD;&#xA;    &#xD;&#xA;    debugMsg = &quot;Step 3: Loading document.xml&quot;&#xD;&#xA;    Dim xmlPath As String = System.IO.Path.Combine(tempFolder, &quot;word&quot;, &quot;document.xml&quot;)&#xD;&#xA;    Dim xmlDoc As New System.Xml.XmlDocument()&#xD;&#xA;    xmlDoc.Load(xmlPath)&#xD;&#xA;    &#xD;&#xA;    debugMsg = &quot;Step 4: Setting up namespace manager&quot;&#xD;&#xA;    Dim nsManager As New System.Xml.XmlNamespaceManager(xmlDoc.NameTable)&#xD;&#xA;    nsManager.AddNamespace(&quot;w&quot;, &quot;http://schemas.openxmlformats.org/wordprocessingml/2006/main&quot;)&#xD;&#xA;    &#xD;&#xA;    debugMsg = &quot;Step 5: Finding first matching text node&quot;&#xD;&#xA;    Dim allTextNodes As System.Xml.XmlNodeList = xmlDoc.SelectNodes(&quot;//w:t&quot;, nsManager)&#xD;&#xA;    Dim targetRun As System.Xml.XmlNode = Nothing&#xD;&#xA;    &#xD;&#xA;    For Each textNode As System.Xml.XmlNode In allTextNodes&#xD;&#xA;        If textNode.InnerText.Contains(searchText) Then&#xD;&#xA;            targetRun = textNode.ParentNode ' this is the &lt;w:r&gt; run element&#xD;&#xA;            Exit For&#xD;&#xA;        End If&#xD;&#xA;    Next&#xD;&#xA;    &#xD;&#xA;    debugMsg = &quot;Step 6: Checking if text was found&quot;&#xD;&#xA;    If targetRun Is Nothing Then&#xD;&#xA;        debugMsg = &quot;Text not found in document&quot;&#xD;&#xA;        Return&#xD;&#xA;    End If&#xD;&#xA;    &#xD;&#xA;    debugMsg = &quot;Step 7: Looking for existing rPr node&quot;&#xD;&#xA;    Dim rPr As System.Xml.XmlNode = targetRun.SelectSingleNode(&quot;w:rPr&quot;, nsManager)&#xD;&#xA;    &#xD;&#xA;    If rPr Is Nothing Then&#xD;&#xA;        debugMsg = &quot;Step 8: Creating new rPr node&quot;&#xD;&#xA;        rPr = xmlDoc.CreateElement(&quot;w&quot;, &quot;rPr&quot;, &quot;http://schemas.openxmlformats.org/wordprocessingml/2006/main&quot;)&#xD;&#xA;        targetRun.InsertBefore(rPr, targetRun.FirstChild)&#xD;&#xA;    End If&#xD;&#xA;    &#xD;&#xA;    debugMsg = &quot;Step 9: Injecting color node&quot;&#xD;&#xA;    Dim colorNode As System.Xml.XmlElement = xmlDoc.CreateElement(&quot;w&quot;, &quot;color&quot;, &quot;http://schemas.openxmlformats.org/wordprocessingml/2006/main&quot;)&#xD;&#xA;    colorNode.SetAttribute(&quot;val&quot;, &quot;http://schemas.openxmlformats.org/wordprocessingml/2006/main&quot;, &quot;FF0000&quot;)&#xD;&#xA;    rPr.AppendChild(colorNode)&#xD;&#xA;    &#xD;&#xA;    debugMsg = &quot;Step 10: Saving modified XML&quot;&#xD;&#xA;    xmlDoc.Save(xmlPath)&#xD;&#xA;    &#xD;&#xA;    debugMsg = &quot;Step 11: Repackaging docx&quot;&#xD;&#xA;    If System.IO.File.Exists(docPath) Then&#xD;&#xA;        System.IO.File.Delete(docPath)&#xD;&#xA;    End If&#xD;&#xA;    System.IO.Compression.ZipFile.CreateFromDirectory(tempFolder, docPath)&#xD;&#xA;    &#xD;&#xA;    debugMsg = &quot;Step 12: Cleaning up temp folder&quot;&#xD;&#xA;    System.IO.Directory.Delete(tempFolder, True)&#xD;&#xA;    &#xD;&#xA;    debugMsg = &quot;Completed successfully&quot;&#xD;&#xA;&#xD;&#xA;Catch ex As Exception&#xD;&#xA;    debugMsg = &quot;Failed at: &quot; &amp; debugMsg &amp; &quot; | Error: &quot; &amp; ex.Message&#xD;&#xA;End Try" DisplayName="Invoke Code - Upload File" sap:VirtualizedContainerService.HintSize="450,197.33333333333334" sap2010:WorkflowViewState.IdRef="InvokeCode_1">
