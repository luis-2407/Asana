    <ui:InvokeCode ContinueOnError="{x:Null}" Code="Dim wordApp As New Microsoft.Office.Interop.Word.Application&#xD;&#xA;Dim doc As Microsoft.Office.Interop.Word.Document = Nothing&#xD;&#xA; &#xD;&#xA;Try&#xD;&#xA;    wordApp.Visible = False&#xD;&#xA;    doc = wordApp.Documents.Open(CStr(in_FilePath))&#xD;&#xA; &#xD;&#xA;    Dim findRange As Microsoft.Office.Interop.Word.Range = doc.Content&#xD;&#xA; &#xD;&#xA;    With findRange.Find&#xD;&#xA;        .ClearFormatting()&#xD;&#xA;        .Text = CStr(in_SearchText)&#xD;&#xA;        .Forward = True&#xD;&#xA;        .Wrap = Microsoft.Office.Interop.Word.WdFindWrap.wdFindStop&#xD;&#xA;        .Format = False&#xD;&#xA;    End With&#xD;&#xA; &#xD;&#xA;    Do While findRange.Find.Execute()&#xD;&#xA;        findRange.HighlightColorIndex = Microsoft.Office.Interop.Word.WdColorIndex.wdYellow&#xD;&#xA;        findRange.Collapse(Microsoft.Office.Interop.Word.WdCollapseDirection.wdCollapseEnd)&#xD;&#xA;    Loop&#xD;&#xA; &#xD;&#xA;    doc.Save()&#xD;&#xA; &#xD;&#xA;Finally&#xD;&#xA;    If doc IsNot Nothing Then&#xD;&#xA;        doc.Close(False)&#xD;&#xA;    End If&#xD;&#xA; &#xD;&#xA;    If wordApp IsNot Nothing Then&#xD;&#xA;        wordApp.Quit()&#xD;&#xA;    End If&#xD;&#xA;End Try" DisplayName="Invoke Code" sap:VirtualizedContainerService.HintSize="450,197.33333333333334" sap2010:WorkflowViewState.IdRef="InvokeCode_2">
