    <ui:InvokeCode ContinueOnError="{x:Null}" Code="'=== Upload attachment to Asana preserving filename (including commas) ===&#xD;&#xA;'Inputs:&#xD;&#xA;'  inPersonalAccessToken As String&#xD;&#xA;'  inTaskGid As String&#xD;&#xA;'  inFilePath As String&#xD;&#xA;'Outputs:&#xD;&#xA;'  outStatusCode As Integer&#xD;&#xA;'  outResponse As String&#xD;&#xA;'Optional debug outputs (create if you want):&#xD;&#xA;'  outFileName As String&#xD;&#xA;'  outHasComma As String&#xD;&#xA;'  outDebugContentDisposition As String&#xD;&#xA;&#xD;&#xA;Dim url As String = &quot;https://app.asana.com/api/1.0/attachments&quot;&#xD;&#xA;Dim responseText As String = &quot;&quot;&#xD;&#xA;Dim statusCodeValue As Integer = -1&#xD;&#xA;&#xD;&#xA;Try&#xD;&#xA;    Using client As New System.Net.Http.HttpClient()&#xD;&#xA;&#xD;&#xA;        ' Auth&#xD;&#xA;        client.DefaultRequestHeaders.Authorization =&#xD;&#xA;            New System.Net.Http.Headers.AuthenticationHeaderValue(&quot;Bearer&quot;, inPersonalAccessToken)&#xD;&#xA;&#xD;&#xA;        ' Build multipart form&#xD;&#xA;        Using form As New System.Net.Http.MultipartFormDataContent()&#xD;&#xA;&#xD;&#xA;            ' Required: parent (task GID)&#xD;&#xA;            form.Add(New System.Net.Http.StringContent(inTaskGid), &quot;parent&quot;)&#xD;&#xA;&#xD;&#xA;            ' Required: file (binary)&#xD;&#xA;            Dim bytes As Byte() = System.IO.File.ReadAllBytes(inFilePath)&#xD;&#xA;            Dim fileName As String = System.IO.Path.GetFileName(inFilePath)&#xD;&#xA;&#xD;&#xA;            ' Optional debug&#xD;&#xA;            'outFileName = fileName&#xD;&#xA;            'outHasComma = fileName.Contains(&quot;,&quot;).ToString()&#xD;&#xA;&#xD;&#xA;            Dim fileContent As New System.Net.Http.ByteArrayContent(bytes)&#xD;&#xA;            fileContent.Headers.ContentType =&#xD;&#xA;                New System.Net.Http.Headers.MediaTypeHeaderValue(&quot;application/octet-stream&quot;)&#xD;&#xA;&#xD;&#xA;            ' IMPORTANT:&#xD;&#xA;            ' Set Content-Disposition ONCE using typed header (avoids comma being treated as separator).&#xD;&#xA;            Dim cd As New System.Net.Http.Headers.ContentDispositionHeaderValue(&quot;form-data&quot;)&#xD;&#xA;            cd.Name = &quot;&quot;&quot;file&quot;&quot;&quot;&#xD;&#xA;            cd.FileName = &quot;&quot;&quot;&quot; &amp; fileName &amp; &quot;&quot;&quot;&quot;&#xD;&#xA;            cd.FileNameStar = fileName   ' RFC 5987 encoding - most robust for special chars&#xD;&#xA;            fileContent.Headers.ContentDisposition = cd&#xD;&#xA;&#xD;&#xA;            ' Add WITHOUT filename overload to avoid a second Content-Disposition being generated&#xD;&#xA;            form.Add(fileContent, &quot;file&quot;)&#xD;&#xA;&#xD;&#xA;            ' Optional debug: inspect the final header value that will be sent&#xD;&#xA;            'outDebugContentDisposition = fileContent.Headers.ContentDisposition.ToString()&#xD;&#xA;&#xD;&#xA;            ' Send&#xD;&#xA;            Dim resp As System.Net.Http.HttpResponseMessage = client.PostAsync(url, form).Result&#xD;&#xA;            statusCodeValue = CInt(resp.StatusCode)&#xD;&#xA;            responseText = resp.Content.ReadAsStringAsync().Result&#xD;&#xA;&#xD;&#xA;        End Using&#xD;&#xA;    End Using&#xD;&#xA;&#xD;&#xA;Catch ex As Exception&#xD;&#xA;    ' Capture exception details if you want (optional)&#xD;&#xA;    responseText = &quot;EXCEPTION: &quot; &amp; ex.GetType().FullName &amp; &quot; - &quot; &amp; ex.Message&#xD;&#xA;    statusCodeValue = -1&#xD;&#xA;End Try&#xD;&#xA;&#xD;&#xA;outStatusCode = statusCodeValue&#xD;&#xA;outResponse = responseText" DisplayName="Invoke Code - Upload File" sap:VirtualizedContainerService.HintSize="450,188" sap2010:WorkflowViewState.IdRef="InvokeCode_1">
