 String.Join(&quot; &quot;, kept)&#xA;    End Function&#xA;&#xA;Dim RemoveTrailingCredentials As System.Func(Of String, String) =&#xA;    Function(text As String)&#xA;        Dim toks = WordTokensPreserveDots(text)&#xA;        Dim i As Integer = toks.Count - 1&#xA;        While i &gt;= 0 AndAlso IsCredentialsToken(toks(i))&#xA;            i -= 1&#xA;        End While&#xA;        If i &lt; 0 Then Return &quot;&quot;&#xA;        Dim kept = toks.GetRange(0, i + 1)&#xA;        Return String.Join(&quot; &quot;, kept)&#xA;    End Function&#xA;&#xA;Dim RemoveTrailingCredentialCommaChunk As System.Func(Of String, String) =&#xA;    Function(text As String)&#xA;        Dim idx = (If(text, &quot;&quot;)).IndexOf(&quot;,&quot;c)&#xA;        If idx &lt; 0 Then Return text&#xA;        Dim left = text.Substring(0, idx).Trim()&#xA;        Dim right = text.Substring(idx + 1).Trim()&#xA;        Dim parts = SplitByComma(right)&#xA;        If IsAllCredentials(parts) Then&#xA;            Return left&#xA;        End If&#xA;        Return text&#xA;    End Function&#xA;&#xA;' --- Main branching: comma vs no comma ---&#xA;Dim firstComma As Integer = s.IndexOf(&quot;,&quot;c)&#xA;If firstComma &gt;= 0 Then&#xA;    Dim left = s.Substring(0, firstComma).Trim()&#xA;    Dim right = s.Substring(firstComma + 1).Trim()&#xA;    Dim rightParts = SplitByComma(right)&#xA;&#xA;    If IsAllCredentials(rightParts) Then&#xA;        ' Treat as western order&#xA;        s = left&#xA;        ' Fall through to western parsing below&#xA;        firstComma = -1&#xA;    Else&#xA;        ' &quot;Last, First [Middle] [, Suffix] [, Credentials]&quot;&#xA;        Dim suffix As String = &quot;&quot;&#xA;        Dim filteredRight As New System.Collections.Generic.List(Of String)&#xA;        For Each part In rightParts&#xA;            Dim p = part.Trim()&#xA;            If p.Length = 0 Then Continue For&#xA;            If IsSuffixToken(p) Then&#xA;                suffix = p&#xA;            ElseIf Not IsCredentialsBlob(p